# 大模型 API 配置
# 请根据实际情况修改以下配置

# API 密钥（必填）
OPENAI_API_KEY=your_api_key_here

# API 基础 URL（可选，默认为 DeepSeek）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 模型名称（可选，默认为 deepseek-v4-flash）
OPENAI_MODEL=deepseek-v4-flash

# 系统提示词（可选）
LLM_SYSTEM_PROMPT=You are a helpful assistant with access to tools. Use them when needed.

# 温度参数（可选，默认 0.7）
LLM_TEMPERATURE=0.7

# Embedding 配置
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://llm-dn8yb29rpv1wjhvi.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4