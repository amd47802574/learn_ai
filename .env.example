# 大模型 API 配置
# 请根据实际情况修改以下配置

# API 密钥（必填）
OPENAI_API_KEY=your_api_key_here

# API 基础 URL（可选）
OPENAI_BASE_URL=your_base_url_here

# 模型名称（可选）
OPENAI_MODEL=your_model_name_here

# 系统提示词（可选）
LLM_SYSTEM_PROMPT=You are a helpful assistant with access to tools. Use them when needed.

# 温度参数（可选，默认 0.7）
LLM_TEMPERATURE=0.7
